          "format": "table",
          "rawSql": "SELECT ROUND(COALESCE(COUNT(*) FILTER (WHERE profit > 0) * 100.0 / NULLIF(COUNT(*), 0), 0), 1) AS win_rate FROM trades WHERE ($symbol = 'all' OR symbol = $symbol) AND $__timeFilter(time)",
